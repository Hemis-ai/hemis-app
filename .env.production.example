# ── Production environment — copy values into Vercel env vars (main branch) ──

NEXT_PUBLIC_APP_URL=https://hemisx.com

# GitHub OAuth — production OAuth App
# Homepage URL: https://hemisx.com
# Callback URL: https://hemisx.com/api/github/oauth/callback
GITHUB_CLIENT_ID=your_production_client_id
GITHUB_CLIENT_SECRET=your_production_client_secret

# ── Feature flags — flip to true only when product is launch-ready ───────────
NEXT_PUBLIC_FEATURE_SAST=true       # ✅ live
NEXT_PUBLIC_FEATURE_DAST=false      # 🔒 hidden until DAST ships
NEXT_PUBLIC_FEATURE_BLUETEAM=false  # 🔒 hidden until Blue Team ships
NEXT_PUBLIC_FEATURE_SCANNER=false   # 🔒 hidden until Scanner ships
