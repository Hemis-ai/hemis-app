# ── Staging environment — copy values into Vercel env vars (staging branch) ──

NEXT_PUBLIC_APP_URL=https://staging.hemisx.com

# GitHub OAuth — create a SEPARATE OAuth App for staging
# Homepage URL: https://staging.hemisx.com
# Callback URL: https://staging.hemisx.com/api/github/oauth/callback
GITHUB_CLIENT_ID=your_staging_client_id
GITHUB_CLIENT_SECRET=your_staging_client_secret

# ── Feature flags — all ON in staging so both devs can test ──────────────────
NEXT_PUBLIC_FEATURE_SAST=true
NEXT_PUBLIC_FEATURE_DAST=true
NEXT_PUBLIC_FEATURE_BLUETEAM=true
NEXT_PUBLIC_FEATURE_SCANNER=true
